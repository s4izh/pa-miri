#!/usr/bin/env python3
import argparse
import argcomplete
import os
import subprocess
import sys
from pathlib import Path

def find_proj_root():
    """Detect or export PROJ_DIR automatically."""
    env_root = os.getenv("PROJ_DIR")
    if env_root:
        root = Path(env_root).resolve()
        if root.exists():
            return root

    current = Path(__file__).resolve()
    for parent in [current] + list(current.parents):
        if (parent / "sim").is_dir() and (parent / "rtl").is_dir():
            os.environ["PROJ_DIR"] = str(parent)
            print(f"[INFO] PROJ_DIR not set — auto-detected and exported: {parent}")
            return parent
    sys.exit("[ERROR] Could not determine project root. Please export PROJ_DIR manually.")

PROJ_DIR = find_proj_root()
SIM_ROOT = PROJ_DIR / "sim"
SIM_COMMON = SIM_ROOT / "common"
SIM_SCRIPTS = SIM_ROOT / "scripts"

def list_tests():
    """
    A valid test is any directory under sim/ that contains a filelist.f.
    """
    tests = []
    for filelist_path in SIM_ROOT.rglob("filelist.f"):
        test_dir = filelist_path.parent
        relative_path = test_dir.relative_to(SIM_ROOT)
        test_name = ".".join(relative_path.parts)
        tests.append(test_name)
    return sorted(tests)

def test_name_to_folder(test_name):
    path_parts = test_name.split(".")
    return SIM_ROOT.joinpath(*path_parts)

def test_name_to_build_dir(test_name, sim):
    parts = test_name.split(".")
    return PROJ_DIR / "build" / "/".join(parts) / sim

def relative_to_absolute(path) -> str:
    if path[0] == "/":
        return path
    return Path.cwd() / path

def list_simulators():
    return sorted([f.stem for f in SIM_SCRIPTS.glob("*.mk")])

def run_make(test, action, sim, rom_file):
    test_dir = test_name_to_folder(test)
    build_dir = test_name_to_build_dir(test, sim)

    env = os.environ
    env["PROJ_DIR"] = str(PROJ_DIR)
    env["BUILD_DIR"] = str(build_dir)

    cmd = ["make", "-C", str(test_dir), action]
    if action != "clean":
        cmd.append(f"SIM={sim}")
    if rom_file != "":
        cmd.append(f"ROM_FILE={relative_to_absolute(rom_file)}")

    print(f"[RUNNING] {' '.join(cmd)}")

    try:
        result = subprocess.run(cmd, check=True, env=env, capture_output=True, text=True)
        stdout = result.stdout
        if "Nothing to be done" in stdout:
            print(f"[SKIPPED] {test} ({sim}) {action} skipped — targets up to date")
        elif action == "clean":
            print(f"[CLEAN] {test} cleaned")
        else:
            print(f"{stdout}", end="")
            print(f"[SUCCESS] {test} ({sim}) {action}")
            # print(f"[SUCCESS] {action} --test {test} --sim {sim}")
        return True
    except subprocess.CalledProcessError as e:
        print(f"[FAIL] {test} ({sim}) {action} failed with exit code {e.returncode}")
        print(f"{e.stdout}\n{e.stderr}")
        return False
    except KeyboardInterrupt:
        print(f"\n[INTERRUPTED] Stopped while running {test}")
        sys.exit(1)

def main():
    tests = list_tests()
    sims = list_simulators()

    tests_help = "\n".join(f"  - {t}" for t in tests) or "  (none found)"
    sims_help = "\n".join(f"  - {s}" for s in sims) or "  (none found)"

    parser = argparse.ArgumentParser(
        description=f"""PA Orchestrator

Available tests (select with --test):
{tests_help}

Available simulators (select with --sim):
{sims_help}
""",
        formatter_class=argparse.RawTextHelpFormatter,
    )
    parser.add_argument("action", choices=["compile", "simulate", "waves", "clean"],
                        help="Action to perform (compile/simulate/waves/clean).")
    parser.add_argument("--test", choices=tests, help="Specific test name (omit for all).")
    parser.add_argument("--sim", choices=sims, default="iverilog", help="Simulator (default: iverilog).")
    parser.add_argument("--rom_file", default="", help="Path to file with hex contents of the ROM (default: Empty).")
    parser.add_argument("--verbose", "-v", action="store_true", help="Print debug info.")

    argcomplete.autocomplete(parser)

    args = parser.parse_args()

    if args.verbose:
        print(f"PROJ_DIR = {PROJ_DIR}")
        print(f"Detected tests: {tests}")
        print(f"Detected simulators: {sims}")

    if args.sim not in sims:
        sys.exit(f"[ERROR] Simulator '{args.sim}' not found. Available: {', '.join(sims)}")

    failed = []

    if args.test:
        if args.test not in tests:
            sys.exit(f"[ERROR] Test '{args.test}' not found among: {', '.join(tests)}")
        ok = run_make(args.test, args.action, args.sim, args.rom_file)
        if not ok:
            failed.append(args.test)
    else:
        for t in tests:
            ok = run_make(t, args.action, args.sim, args.rom_file)
            if not ok:
                failed.append(t)

    if failed:
        print("Some tests failed:")
        for f in failed:
            print(f"   - {f}")
        sys.exit(1)

if __name__ == "__main__":
    main()

