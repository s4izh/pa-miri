#!/usr/bin/env python3
import argparse
import os
import subprocess
import sys
from pathlib import Path

def find_proj_root():
    """Detect or export PROJ_DIR automatically."""
    env_root = os.getenv("PROJ_DIR")
    if env_root:
        root = Path(env_root).resolve()
        if root.exists():
            return root

    current = Path(__file__).resolve()
    for parent in [current] + list(current.parents):
        if (parent / "sim").is_dir() and (parent / "rtl").is_dir():
            os.environ["PROJ_DIR"] = str(parent)
            return parent
    sys.exit("[ERROR] Could not determine project root. Please export PROJ_DIR manually.")

PROJ_DIR = find_proj_root()
SIM_SCRIPTS = PROJ_DIR / "sim" / "scripts"

def list_simulators():
    """Finds available simulators from the sim/scripts directory."""
    return sorted([f.stem for f in SIM_SCRIPTS.glob("*.mk")])

def build_benchmarks():
    """Runs the Ninja build system to compile all C benchmarks."""
    print("Step 1: Building benchmarks")
    try:
        subprocess.run(["lua", "build.lua"], cwd=PROJ_DIR, check=True, capture_output=True, text=True)
        print("[RUNNING] ninja benchmarks")
        subprocess.run(["ninja", "benchmarks"], cwd=PROJ_DIR, check=True, text=True)
        print("Build complete")
        return True
    except (subprocess.CalledProcessError, FileNotFoundError) as e:
        print(f"[FAIL] Benchmark build failed: {e}", file=sys.stderr)
        return False

def run_simulation_with_orchestrator(sim, rom_path, sram_path, timeout, verbose):
    """
    Executes a single benchmark simulation by calling the main orchestrator script
    and verifies the outcome by checking the generated log file.
    """
    program_name = rom_path.relative_to(PROJ_DIR / "build")
    print(f"Simulating: {program_name}")

    test_harness = "rv_pa1.anyrom"

    cmd = [
        "./tools/orchestrator", "simulate",
        "--test", test_harness,
        "--sim", sim,
        "--rom_file", str(rom_path),
        "--sram_file", str(sram_path),
        f"--timeout={timeout}"
    ]

    print(f"[RUNNING] {' '.join(cmd)}")

    # Add the verbose flag to the command if requested
    # if verbose:
    #     cmd.append("--verbose")
    
    capture = 1
    result = subprocess.run(cmd, capture_output=capture, text=True)

    build_dir = PROJ_DIR / "build" / test_harness.replace('.', '/') / sim
    rel_path = rom_path.relative_to(PROJ_DIR / "build")
    target_rel_path = Path(str(rel_path).replace('.rom.hex', ''))
    log_file = build_dir / "outputs" / target_rel_path.with_suffix('.log')

    if result.returncode != 0:
        print(f"[FAIL] Orchestrator failed for {program_name} with exit code {result.returncode}", file=sys.stderr)
        if capture:
            print(result.stdout)
            print(result.stderr)
        return False

    try:
        log_content = log_file.read_text()
        if "** SIMULATION PASSED **" in log_content:
            print(result.stdout)
            print(f"[FINISHED] {program_name}")
            return True
        else:
            print(f"[FAIL] Pass message not found in log for {program_name}", file=sys.stderr)
            return False
    except FileNotFoundError:
        print(f"[FAIL] Log file not found at {log_file} for {program_name}", file=sys.stderr)
        return False

def main():
    sims = list_simulators()
    parser = argparse.ArgumentParser(
        description="A script to build and run all C benchmarks for the RISC-V project.",
        formatter_class=argparse.RawTextHelpFormatter
    )
    parser.add_argument("--sim", choices=sims, default="vsim", help="Simulator to use (default: vsim).")
    parser.add_argument("--timeout", default=5000, type=int, help="Number of simulation cycles before timeout (default: 5000).")
    parser.add_argument("--verbose", "-v", action="store_true", help="Print detailed simulator output.")

    args = parser.parse_args()

    if not build_benchmarks():
        sys.exit(1)

    benchmarks_dir = PROJ_DIR / "build" / "programs" / "benchmarks"
    benchmark_roms = sorted(benchmarks_dir.rglob("*.rom.hex"))

    if not benchmark_roms:
        sys.exit("[ERROR] No compiled benchmarks found in 'build/programs/benchmarks/'.")

    print(f"Step 2: Found {len(benchmark_roms)} benchmarks to simulate")

    failed_benchmarks = []
    for rom_path in benchmark_roms:
        print("-" * 60)
        sram_path = rom_path.with_name(rom_path.name.replace(".rom.hex", ".sram.hex"))
        
        ok = run_simulation_with_orchestrator(
            args.sim, 
            rom_path, 
            sram_path if sram_path.exists() else "", 
            args.timeout,
            args.verbose
        )
        if not ok:
            failed_benchmarks.append(rom_path.relative_to(PROJ_DIR / "build"))

    print("================== BENCHMARK SUMMARY ==================")
    if not failed_benchmarks:
        print("All benchmarks PASSED!")
        sys.exit(0)
    else:
        print(f"{len(failed_benchmarks)} benchmark(s) FAILED: ")
        for f in failed_benchmarks:
            print(f"  - {f}")
        sys.exit(1)

if __name__ == "__main__":
    main()
