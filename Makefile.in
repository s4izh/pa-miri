REQUIRED_VARS := PROJ_DIR TARGET FILELIST BUILD_DIR SIM WAVE_FILE LOG_FILE

$(foreach var,$(REQUIRED_VARS),\
  $(if $(value $(var)),,$(error Missing required variable: $(var))))

SV_FILES := $(shell python3 $(PROJ_DIR)/tools/parse_filelist.py $(FILELIST))

BUILD_DIR ?= $(PROJ_DIR)/build/$(TARGET)/$(SIM)
BUILD_DIR ?= $(PROJ_DIR)/cosim

include $(PROJ_DIR)/sim/scripts/$(SIM).mk

REQUIRED_VARS_POST := COMPILE_COMMAND SIM_COMMAND CLEAN_COMMAND COMPILED_FILE

$(foreach var,$(REQUIRED_VARS_POST),\
  $(if $(value $(var)),,$(error Missing required variable after include: $(var))))

$(info --- MAKE DEBUG ---)
$(info TARGET            = $(TARGET))
$(info SIM               = $(SIM))
$(info FILELIST          = $(FILELIST))
# $(info SV_FILES          = $(SV_FILES))
$(info COMPILED_FILE     = $(COMPILED_FILE))
$(info COMPILE_COMMAND   = $(COMPILE_COMMAND))
$(info SIM_COMMAND       = $(SIM_COMMAND))
$(info CLEAN_COMMAND     = $(CLEAN_COMMAND))
$(info --- END DEBUG ---)

.PHONY: all compile simulate waves clean lint

WAVE_VIEWER ?= gtkwave
SAVE_FILE   ?= $(PROJ_DIR)/savefile.gtkw

COMPILED_COSIM  ?= $(PROJ_DIR)/cosim/cosim_dpi.a

all: simulate

compile: $(COMPILED_COSIM) $(COMPILED_FILE)

$(COMPILED_COSIM): $(SV_FILES)
	make -C $(PROJ_DIR)/cosim

$(COMPILED_FILE): $(SV_FILES)
	@echo "[COMPILE]"
	@mkdir -p $(BUILD_DIR)
	cd $(BUILD_DIR) && $(COMPILE_COMMAND)

simulate: compile $(COMPILED_FILE)
	@echo "[SIMULATE]"
	$(ROM_COMPILE_COMMAND)
	cd $(BUILD_DIR) && $(SIM_COMMAND)

waves: simulate
	@echo "[WAVES]"
	$(WAVE_VIEWER) $(WAVE_FILE)

clean:
	@echo "[CLEAN] Removing build files"
	@echo $(SIM) $(CLEAN_COMMAND)
	$(CLEAN_COMMAND)

lint:
	@echo "[LINT] Running Slang linter on target: $(TARGET)"
	@slang --version
	@slang -Werror $(SV_FILES)

